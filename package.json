{
  "name": "my-personal-page",
  "version": "0.1.0",
  "private": true,
  "description": "Shendy's personal portfolio monorepo",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "build": "npm run db:generate && npm run build --workspace=web",
    "start": "npm run start --workspace=web",
    "lint": "npm run lint --workspace=web",
    "db:seed": "npm run db:seed --workspace=web",
    "db:generate": "npm exec --workspace=web -- prisma generate",
    "db:migrate": "npm exec --workspace=web -- prisma migrate dev",
    "db:studio": "npm exec --workspace=web -- prisma studio",
    "postinstall": "npm run db:generate",
    "images:optimize": "npm run images:optimize --workspace=web"
  },
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=9.0.0"
  }
}
